# ════════════════════════════════════════════════
# Zunor — Environment Variables
# ════════════════════════════════════════════════
# Скопіюй цей файл як .env та заповни своїми значеннями:
#   PowerShell:  Copy-Item .env.example .env
#   Bash:        cp .env.example .env
#
# ⚠️ Ніколи не комітьте .env у git — він у .gitignore.


# ─── База даних ─────────────────────────────────
# PostgreSQL connection string.
# Локально: postgresql://user:password@localhost:5432/zunor
# Продакшн: бери з Supabase / Neon / Railway dashboard.
DATABASE_URL=


# ─── Better-Auth (авторизація) ──────────────────
# Базовий URL застосунку. Без слешу в кінці.
# Dev:  http://localhost:5173
# Прод: https://zunor.org
BETTER_AUTH_URL=

# Секрет для підпису сесій. Згенеруй:
#   openssl rand -base64 32
# Або: https://generate-secret.vercel.app/32
BETTER_AUTH_SECRET=


# ─── SMTP (відправка email) ─────────────────────
# Gmail як SMTP-провайдер. Для іншого сервісу — заміни хост.
#
# Для Gmail потрібен App Password (не звичайний пароль):
#   1. Увімкни 2FA у Google account
#   2. https://myaccount.google.com/apppasswords
#   3. Створи новий App Password, скопіюй сюди
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Від кого приходить лист (видно отримувачу):
SMTP_FROM=Zunor <noreply@zunor.org>


# ─── Cloudinary (зберігання зображень) ──────────
# Реєстрація: https://cloudinary.com/users/register/free
# Усі ключі — у Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# ─── Pusher Channels (realtime) ─────────────────
# Реєстрація: https://dashboard.pusher.com/accounts/sign_up
# Створи Channels app, бери ключі з App Keys tab.
# Cluster обирай географічно ближчий: eu, ap1, mt1, us2, us3 і т.д.
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=eu

# Публічні (доступні в браузері — це нормально):
# Мають збігатися з PUSHER_KEY та PUSHER_CLUSTER вище.
PUBLIC_PUSHER_KEY=
PUBLIC_PUSHER_CLUSTER=eu


# ─── Cron (внутрішні задачі) ────────────────────
# Будь-який довгий випадковий рядок. Використовується як Bearer token
# у GET /api/cron, щоб ніхто чужий не запускав крон.
# Згенеруй: openssl rand -hex 32
CRON_SECRET=